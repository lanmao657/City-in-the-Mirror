                },
                {
                    "id": "li_02",
                    "type": "choice",
                    "context": "砾请你帮忙传达一句话。那句话是真话。",
                    "choices": {
                        "truth": {
                            "text": "传达砾的真话——「我喜欢你」——给瑶。",
                            "response": "谢谢你。",
